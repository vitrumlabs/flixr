default_platform :ios

platform :ios do

  # ---------------------------------------------------------------------------
  # beta — builds Release and uploads to TestFlight
  #
  # Prerequisites (one-time):
  #   1. Create App Store Connect API key (see Appfile comments)
  #   2. Create vitrumlabs/ios-certs private repo
  #   3. Run: bundle exec fastlane match appstore
  #   4. Place Config/Release/GoogleService-Info.plist (prod Firebase project)
  #
  # Run:
  #   bundle exec fastlane beta
  # ---------------------------------------------------------------------------
  lane :beta do
    # Create a named keychain with a known password so `security set-key-partition-list`
    # can set the ACL after match imports the distribution cert (required on macOS 12+).
    if is_ci
      # Delete any stale keychain from a previous run on this runner before creating fresh.
      sh("security delete-keychain build.keychain 2>/dev/null || true")
      create_keychain(
        name: "build.keychain",
        password: ENV["MATCH_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        add_to_search_list: true
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    # Sync App Store distribution cert + provisioning profile.
    # keychain_password is NOT passed: match-stored .p12s have empty export password;
    # passing MATCH_PASSWORD here would make `security import -P MATCH_PASSWORD` fail.
    # The keychain is already unlocked above via create_keychain.
    match(
      type: "appstore",
      readonly: true,
      keychain_name: is_ci ? "build.keychain" : nil
    )

    # Increment build number to current timestamp (avoids TestFlight rejection for duplicate build)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "flixr.xcodeproj"
    )

    build_app(
      workspace: "flixr.xcworkspace",
      scheme: "flixr",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "vitrumlabs.flixr" => "match AppStore vitrumlabs.flixr"
        }
      },
      output_directory: "build",
      output_name: "flixr.ipa",
      clean: true,
      disable_xcpretty: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: "Internal build"
    )

    clean_build_artifacts
  end

  # ---------------------------------------------------------------------------
  # beta_dev — builds an ad-hoc Debug binary (dev Firebase) and distributes
  # via Firebase App Distribution. Use this to share dev builds with testers
  # without going through TestFlight or touching prod Firebase.
  #
  # Prerequisites (one-time):
  #   bundle exec fastlane add_plugin firebase_app_distribution
  #   bundle exec fastlane match adhoc
  #
  # Run:
  #   bundle exec fastlane beta_dev
  # ---------------------------------------------------------------------------
  lane :beta_dev do
    match(type: "adhoc", readonly: true)

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "flixr.xcodeproj"
    )

    build_app(
      workspace: "flixr.xcworkspace",
      scheme: "flixr",
      configuration: "Debug",
      export_method: "ad-hoc",
      export_options: {
        provisioningProfiles: {
          "vitrumlabs.flixr" => "match AdHoc vitrumlabs.flixr"
        }
      },
      output_directory: "build",
      output_name: "flixr-dev.ipa",
      clean: true,
      disable_xcpretty: true
    )

    firebase_app_distribution(
      app: "1:326402391581:ios:513476a69fd723f63dd0f4",
      groups: "internal-testers",
      release_notes: "Dev build — Firebase dev environment"
    )

    clean_build_artifacts
  end

  # ---------------------------------------------------------------------------
  # release — submits current TestFlight build to App Store review
  #
  # Run after a beta build has been tested and approved.
  #   bundle exec fastlane release build:<build_number>
  # ---------------------------------------------------------------------------
  lane :release do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    deliver(
      api_key: api_key,
      app_version: options[:version] || "1.1",
      build_number: options[:build],
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    deliver(
      api_key: api_key,
      skip_screenshots: true,
      skip_binary_upload: true,
      skip_metadata: false,
      languages: ["en-GB"],
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ---------------------------------------------------------------------------
  # upload_screenshots — uploads captured screenshots to App Store Connect.
  #
  # Run after `fastlane screenshots` has produced images in fastlane/screenshots/.
  #   bundle exec fastlane upload_screenshots
  # ---------------------------------------------------------------------------
  lane :upload_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ---------------------------------------------------------------------------
  # screenshots — captures App Store screenshots on simulators.
  #
  # Prerequisites (one-time):
  #   1. Create a test Firebase account (email/password) in Firebase Console dev project
  #   2. Set env vars: SNAPSHOT_TEST_EMAIL and SNAPSHOT_TEST_PASSWORD
  #
  # Run:
  #   SNAPSHOT_TEST_EMAIL=you@example.com SNAPSHOT_TEST_PASSWORD=secret bundle exec fastlane screenshots
  # ---------------------------------------------------------------------------
  lane :screenshots do
    snapshot
  end

  # ---------------------------------------------------------------------------
  # sync_certs — refreshes local signing assets from the ios-certs repo.
  # Run this on a new machine or after cert rotation.
  #   bundle exec fastlane sync_certs
  # ---------------------------------------------------------------------------
  lane :sync_certs do
    match(type: "appstore", readonly: true)
  end

end
